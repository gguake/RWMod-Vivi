<?xml version="1.0" encoding="UTF-8"?>
<Defs>
  <ThingDef Abstract="True" Name="VV_UtilityApparelBase" ParentName="ApparelNoQualityBase">
    <thingCategories>
      <li>VV_ViviTool</li>
    </thingCategories>

    <statBases>
      <ArmorRating_Sharp>0</ArmorRating_Sharp>
      <ArmorRating_Blunt>0</ArmorRating_Blunt>
      <ArmorRating_Heat>0</ArmorRating_Heat>
      <Insulation_Cold>0</Insulation_Cold>
      <Insulation_Heat>0</Insulation_Heat>
    </statBases>
    <apparel>
      <wornGraphicData>
        <renderUtilityAsPack>true</renderUtilityAsPack>
        <north>
          <offset>(0,-0.15)</offset>
        </north>
        <south>
          <offset>(0,-0.15)</offset>
        </south>
        <east>
          <offset>(-0.25,-0.1)</offset>
          <thin><offset>(0.05,0)</offset></thin>
          <hulk><offset>(-0.15,0)</offset></hulk>
          <fat> <offset>(-0.20,0)</offset></fat>
        </east>
        <west>
          <offset>(0.25,-0.1)</offset>
          <thin><offset>(-0.05,0)</offset></thin>
          <hulk><offset>(0.15,0)</offset></hulk>
          <fat> <offset>(0.20,0)</offset></fat>
        </west>
        <male>  <scale>(1.0,1.0)</scale></male>
        <female><scale>(1.0,1.0)</scale></female>
        <thin>  <scale>(1.0,1.0)</scale></thin>
        <hulk>  <scale>(1.2,1.2)</scale></hulk>
        <fat>   <scale>(1.2,1.2)</scale></fat>
      </wornGraphicData>

      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <careIfWornByCorpse>false</careIfWornByCorpse>
      <careIfDamaged>false</careIfDamaged>
      <wearPerDay>0</wearPerDay>

      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <tags>
        <li>VV_ViviApparel</li>
      </tags>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
    </apparel>

    <tradeTags Inherit="False">
      <li>VV_ViviApparel</li>
    </tradeTags>
  </ThingDef>

  <!-- VV_StrawTool -->
  <ThingDef ParentName="VV_UtilityApparelBase">
    <defName>VV_StrawTool</defName>
    <label>vivi straw</label>
    <description>A large straw that Vivis use to collect honey more efficiently. Humans can also use it to collect honey.</description>
    <graphicData>
      <texPath>Things/Apparel/Straw/VV_Straw</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>1500</WorkToMake>
      <Mass>0.1</Mass>
      <Flammability>0.4</Flammability>
      <EquipDelay>0.5</EquipDelay>
    </statBases>

    <equippedStatOffsets>
      <VV_HoneyGatherSpeed>0.5</VV_HoneyGatherSpeed>
      <VV_HoneyGatherYield>1.0</VV_HoneyGatherYield>
    </equippedStatOffsets>
    
    <apparel>
      <wornGraphicPath>Things/Apparel/Straw/VV_Straw</wornGraphicPath>
    </apparel>

    <costStuffCount>35</costStuffCount>
    <stuffCategories>
      <li>VV_Wax</li>
      <li>Woody</li>
    </stuffCategories>
    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
      <researchPrerequisites>
        <li>VV_Tools</li>
      </researchPrerequisites>
      <displayPriority>-500</displayPriority>
    </recipeMaker>
  </ThingDef>

  <!-- VV_MultiuseBrushTool -->
  <ThingDef ParentName="VV_UtilityApparelBase">
    <defName>VV_MultiuseBrushTool</defName>
    <label>vivi multiuse brush</label>
    <description>A large brush that can be used for cleaning pollen or collecting material precisely from plants. It's also very helpful when smoothing rough surfaces, and humans can use it too.</description>
    <graphicData>
      <texPath>Things/Apparel/MultiuseBrush/VV_MultiuseBrush</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>

    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>1800</WorkToMake>
      <Mass>0.3</Mass>
      <Flammability>0.4</Flammability>
      <EquipDelay>0.5</EquipDelay>
    </statBases>

    <equippedStatOffsets>
      <CleaningSpeed>0.5</CleaningSpeed>
      <SmoothingSpeed>0.5</SmoothingSpeed>
      <VV_PlantGatherSpeed>0.25</VV_PlantGatherSpeed>
      <VV_PlantGatherYield>0.25</VV_PlantGatherYield>
    </equippedStatOffsets>
    
    <apparel>
      <wornGraphicPath>Things/Apparel/MultiuseBrush/VV_MultiuseBrush</wornGraphicPath>
    </apparel>

    <costStuffCount>45</costStuffCount>
    <stuffCategories>
      <li>VV_Wax</li>
      <li>Woody</li>
    </stuffCategories>
    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
      <researchPrerequisites>
        <li>VV_Tools</li>
      </researchPrerequisites>
      <displayPriority>-501</displayPriority>
    </recipeMaker>
  </ThingDef>

  <!-- VV_PerfumeBottle -->
  <ThingDef ParentName="VV_UtilityApparelBase">
    <defName>VV_PerfumeBottle</defName>
    <label>vivi perfume bottle</label>
    <description>A waist-worn bottle used to collect and blend the scents of flowers. After collecting scents from flowers or arcane flowers three times, it can create and spray an enchanted fragrance. The completed fragrance can be sprayed six times; once it has all been used, the bottle must be refilled with pollen and blended again.
\nPollen from arcane flowers grants a unique effect that varies by flower, with denser pollen producing a stronger effect.\nPollen from ordinary flowers has no special effect, but improves mood and amplifies the effects of any arcane flower pollen mixed with it.
\nThe art of handling fragrances is a longstanding tradition among the Vivis, but because it is a luxury that consumes a great deal of pollen, it has become uncommon in these recent hard times.</description>
    <thingClass>VVRace.Apparel_PerfumeBottle</thingClass>
    <graphicData>
      <texPath>Things/Item/VV_UnfermentedMead</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>3300</WorkToMake>
      <Mass>0.1</Mass>
      <Flammability>0.25</Flammability>
      <EquipDelay>0.5</EquipDelay>
    </statBases>

    <costList>
      <VV_Pollen>200</VV_Pollen>
      <VV_Viviwax>30</VV_Viviwax>
    </costList>

    <comps>
      <li Class="VVRace.CompProperties_PerfumeBottle">
        <maxIngredients>3</maxIngredients>
        <maxSprays>6</maxSprays>

        <reloadCost>200</reloadCost>
        <reloadTicks>500</reloadTicks>
        <pollenDef>VV_Pollen</pollenDef>

        <gatherTicks>1500</gatherTicks>
        <arcaneWeightPerFlower>0.35</arcaneWeightPerFlower>
        <ordinaryFlowerWeightBonus>0.15</ordinaryFlowerWeightBonus>
      </li>
      <li Class="VVRace.CompProperties_PerfumeVerbOwner" />
    </comps>

    <verbs>
      <li Class="VVRace.VerbProperties_SprayPerfume">
        <label>scatter perfume powder</label>
        <violent>false</violent>
        <range>2.7</range>
        <warmupTime>2</warmupTime>
        <defaultCooldownTime>0</defaultCooldownTime>
        <hasStandardCommand>true</hasStandardCommand>
        <targetable>false</targetable>
        <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
        <onlyManualCast>true</onlyManualCast>
        <requireLineOfSight>false</requireLineOfSight>
        <ai_IsWeapon>false</ai_IsWeapon>
        <targetParams>
          <canTargetSelf>true</canTargetSelf>
          <canTargetLocations>false</canTargetLocations>
          <canTargetPawns>false</canTargetPawns>
          <canTargetBuildings>false</canTargetBuildings>
        </targetParams>
        <commandIcon>Things/Mote/VV_PollenPuff</commandIcon>
      </li>
    </verbs>

    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
      </recipeUsers>
      <researchPrerequisites>
        <li>VV_Perfumery</li>
      </researchPrerequisites>
      <displayPriority>-502</displayPriority>
    </recipeMaker>
  </ThingDef>
</Defs>
