<?xml version="1.0" encoding="UTF-8"?>
<Defs>
  <HediffDef>
    <defName>VV_RoyalVivi</defName>
    <label>royal vivi</label>
    <description>This Vivi has transformed into a Royal Vivi.
\nIt can reproduce by laying eggs and its lifespan is greatly increased. Mental strength and cognitive abilities are developed, but movement speed and work efficiency are reduced.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(1,0.5,0)</defaultLabelColor>
    
    <isBad>false</isBad>
    <priceImpact>false</priceImpact>
    <scenarioCanAdd>false</scenarioCanAdd>
    <everCurableByItem>false</everCurableByItem>

    <alwaysAllowMothballCached>true</alwaysAllowMothballCached>
    <alwaysAllowMothball>true</alwaysAllowMothball>

    <stages>
      <li>
        <makeImmuneTo>
          <li>HeartAttack</li>
        </makeImmuneTo>

        <hungerRateFactorOffset>0.15</hungerRateFactorOffset>
        <statOffsets>
          <WorkSpeedGlobal>-0.4</WorkSpeedGlobal>
          <MoveSpeed>-2</MoveSpeed>
          <NegotiationAbility>0.3</NegotiationAbility>
          <SocialImpact>0.3</SocialImpact>
          <PsychicSensitivity>1.25</PsychicSensitivity>
          <MeditationFocusGain>0.1</MeditationFocusGain>
          <PsychicEntropyRecoveryRate>0.2</PsychicEntropyRecoveryRate>
          <MeleeDodgeChance>-20</MeleeDodgeChance>
        </statOffsets>
        <statFactors>
          <LifespanFactor>20</LifespanFactor>
          <ImmunityGainSpeed>1.8</ImmunityGainSpeed>
        </statFactors>
      </li>
    </stages>

    <comps>
      <li Class="VVRace.HediffCompProperties_AgingFactor">
        <factor>0.2</factor>
      </li>
    </comps>

    <modExtensions>
      <li Class="RPEF.ConstraintModExtension">
        <def>VV_HeartAttackBlockRaceConstraint</def>
      </li>
    </modExtensions>
  </HediffDef>

  <HediffDef>
    <defName>VV_ArchiteGermlineImprint</defName>
    <label>archite germline imprint</label>
    <description>Archites have been imprinted into this Royal Vivi's germline. Egg development speed is increased by 2.5 times, and each egg receives one random archite gene. A second gene is granted with a 50% chance, and a third gene is granted with a 10% chance. After laying an egg, the imprint has a 10% chance to dissipate. This chance increases by 20 percentage points after each egg laid, up to a maximum of 90%.</description>
    <hediffClass>VVRace.Hediff_ArchiteGermlineImprint</hediffClass>
    <defaultLabelColor>(0.4,0.8,1)</defaultLabelColor>

    <isBad>false</isBad>
    <priceImpact>false</priceImpact>
    <scenarioCanAdd>false</scenarioCanAdd>
    <everCurableByItem>false</everCurableByItem>
  </HediffDef>
</Defs>
