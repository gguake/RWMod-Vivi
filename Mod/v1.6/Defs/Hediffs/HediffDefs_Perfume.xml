<?xml version="1.0" encoding="UTF-8"?>
<Defs>
  <HediffDef>
    <defName>VV_ArcanePerfume</defName>
    <label>arcane perfume</label>
    <description>An enchanted fragrance blended from ordinary and arcane flowers. Its properties depend on the scents used in the blend.</description>
    <hediffClass>VVRace.Hediff_ArcanePerfume</hediffClass>
    <defaultLabelColor>(0.95, 0.75, 1)</defaultLabelColor>
    <isBad>false</isBad>
    <priceImpact>false</priceImpact>
    <scenarioCanAdd>false</scenarioCanAdd>
    <everCurableByItem>false</everCurableByItem>
    <initialSeverity>1</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <stages>
      <li><minSeverity>0</minSeverity><becomeVisible>true</becomeVisible></li>
      <li><minSeverity>0.25</minSeverity><becomeVisible>true</becomeVisible></li>
      <li><minSeverity>0.5</minSeverity><becomeVisible>true</becomeVisible></li>
      <li><minSeverity>0.75</minSeverity><becomeVisible>true</becomeVisible></li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>20000~30000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>
</Defs>
