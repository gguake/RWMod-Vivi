<?xml version="1.0" encoding="UTF-8"?>
<Defs>
  <!-- Pollen Emitting -->
  <FleckDef ParentName="FleckBase_Thrown">
    <defName>VV_Fleck_PollenPuff</defName>
    <graphicData>
      <texPath>Things/Mote/VV_PollenPuff</texPath>
      <shaderType>MoteGlow</shaderType>
      <renderInstanced>true</renderInstanced>
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.4</fadeInTime>
    <solidTime>1.2</solidTime>
    <fadeOutTime>3.0</fadeOutTime>
  </FleckDef>
  <EffecterDef>
    <defName>VV_PollenEmitting</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <positionRadius>0.5</positionRadius>
        <fleckDef>VV_Fleck_PollenPuff</fleckDef>
        <burstCount>5~10</burstCount>
        <speed>0.1~0.3</speed>
        <scale>0.8~1.3</scale>
      </li>
    </children>
  </EffecterDef>

  <!-- Gather_Honey -->
  <ThingDef ParentName="MoteBase">
    <defName>VV_Mote_GatherHoney</defName>
    <thingClass>MoteDualAttached</thingClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <mote>
      <solidTime>600</solidTime>
      <rotateTowardsTarget>true</rotateTowardsTarget>
    </mote>
    <graphicData>
      <texPath>Things/Mote/VV_GatherHoney</texPath>
    </graphicData>
  </ThingDef>
  <EffecterDef>
    <defName>VV_Gather_Honey</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_InteractSymbol</subEffecterClass>
        <moteDef>VV_Mote_GatherHoney</moteDef>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <fleckDef>VV_Fleck_PollenPuff</fleckDef>
        <spawnLocType>BetweenPositions</spawnLocType>
        <ticksBetweenMotes>59</ticksBetweenMotes>
        <speed>0.1~0.3</speed>
        <scale>0.7~1.2</scale>
        <angle>0~360</angle>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
      </li>
    </children>
  </EffecterDef>

  <!-- Gather_Perfume -->
  <ThingDef ParentName="MoteBase">
    <defName>VV_Mote_GatherPerfumeBottle</defName>
    <thingClass>MoteDualAttached</thingClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <mote>
      <solidTime>600</solidTime>
      <rotateTowardsTarget>true</rotateTowardsTarget>
    </mote>
    <graphicData>
      <texPath>Things/Item/VV_UnfermentedMead</texPath>
      <drawSize>0.65</drawSize>
    </graphicData>
  </ThingDef>
  <EffecterDef>
    <defName>VV_Gather_Perfume</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_InteractSymbol</subEffecterClass>
        <moteDef>VV_Mote_GatherPerfumeBottle</moteDef>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <fleckDef>VV_Fleck_PollenPuff</fleckDef>
        <spawnLocType>BetweenPositions</spawnLocType>
        <ticksBetweenMotes>59</ticksBetweenMotes>
        <speed>0.1~0.3</speed>
        <scale>0.7~1.2</scale>
        <angle>0~360</angle>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
      </li>
    </children>
  </EffecterDef>


  <!-- Perfume spray: a clockwise pollen ring followed by a radial mist burst. -->
  <FleckDef ParentName="FleckBase_Thrown">
    <defName>VV_Fleck_PerfumeMist</defName>
    <graphicData>
      <texPath>Things/Mote/DustPuff</texPath>
      <shaderType>MoteGlow</shaderType>
      <renderInstanced>true</renderInstanced>
      <color>(1, 1, 1, 1)</color>
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.05</fadeInTime>
    <solidTime>0.15</solidTime>
    <fadeOutTime>1.25</fadeOutTime>
    <useAttachLink>true</useAttachLink>
  </FleckDef>
  <FleckDef ParentName="FleckBase_Thrown">
    <defName>VV_Fleck_PerfumePollen</defName>
    <graphicData>
      <texPath>Things/Mote/VV_PerfumePollenPuff</texPath>
      <shaderType>MoteGlow</shaderType>
      <renderInstanced>true</renderInstanced>
      <color>(1, 1, 1, 1)</color>
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.02</fadeInTime>
    <solidTime>0.25</solidTime>
    <fadeOutTime>0.8</fadeOutTime>
    <useAttachLink>true</useAttachLink>
  </FleckDef>
  <EffecterDef>
    <defName>VV_PerfumeSpray</defName>
    <maintainTicks>61</maintainTicks>
    <children>
      <li>
        <subEffecterClass>VVRace.SubEffecter_PerfumeSpiral</subEffecterClass>
        <fleckDef>VV_Fleck_PerfumeMist</fleckDef>
        <spawnLocType>OnTarget</spawnLocType>
        <ticksBetweenMotes>3</ticksBetweenMotes>
        <burstCount>1</burstCount>
        <positionRadiusMin>0.15</positionRadiusMin>
        <positionRadius>1.0</positionRadius>
        <angle>-15~15</angle>
        <speed>0.2~0.45</speed>
        <rotationRate>-120~120</rotationRate>
        <scale>0.35~1.05</scale>
      </li>
      <li>
        <subEffecterClass>VVRace.SubEffecter_PerfumeSpiral</subEffecterClass>
        <fleckDef>VV_Fleck_PerfumePollen</fleckDef>
        <spawnLocType>OnTarget</spawnLocType>
        <ticksBetweenMotes>2</ticksBetweenMotes>
        <burstCount>2~3</burstCount>
        <positionRadiusMin>0.1</positionRadiusMin>
        <positionRadius>1.2</positionRadius>
        <angle>-20~20</angle>
        <speed>0.4~0.9</speed>
        <rotationRate>-180~180</rotationRate>
        <scale>0.07~0.16</scale>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>VV_Fleck_PerfumeMist</fleckDef>
        <spawnLocType>OnTarget</spawnLocType>
        <burstCount>24~32</burstCount>
        <positionRadius>0.35</positionRadius>
        <angle>0~360</angle>
        <speed>1.2~2.4</speed>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <rotationRate>-120~120</rotationRate>
        <scale>0.5~1</scale>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>VV_Fleck_PerfumePollen</fleckDef>
        <spawnLocType>OnTarget</spawnLocType>
        <burstCount>28~38</burstCount>
        <positionRadiusMin>0.1</positionRadiusMin>
        <positionRadius>0.4</positionRadius>
        <angle>0~360</angle>
        <speed>1.5~3</speed>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <rotationRate>-240~240</rotationRate>
        <scale>0.08~0.18</scale>
      </li>
    </children>
  </EffecterDef>

</Defs>
